# AssApp — Variáveis de Ambiente (Staging)

# Django
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,staging.assapp.example
BASE_DOMAIN=assapp.example

# Database
POSTGRES_DB=assapp_db_staging
POSTGRES_USER=assapp_user_staging
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql://assapp_user_staging:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/assapp_db_staging

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Ports (no droplet staging)
BACKEND_PORT=8001
FRONTEND_PORT=8080

# Frontend / API pública
VITE_API_URL=http://YOUR_STAGING_HOST:8080

# Docker Hub (usado pelo compose de staging)
DOCKER_USERNAME=
IMAGE_TAG=develop

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (opcional)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Multi-tenancy
SYSTEM_TENANT_SCHEMA=sistema
