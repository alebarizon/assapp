# AssApp — Variáveis de Ambiente (Produção)

# Django
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=assapp.example,www.assapp.example,sistema.assapp.example
BASE_DOMAIN=assapp.example

# Database
POSTGRES_DB=assapp_db_prod
POSTGRES_USER=assapp_user_prod
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql://assapp_user_prod:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/assapp_db_prod

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=80

# Frontend / API pública
VITE_API_URL=https://assapp.example

# Docker Hub
DOCKER_USERNAME=
IMAGE_TAG=latest

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Multi-tenancy
SYSTEM_TENANT_SCHEMA=sistema
